# Copia este archivo como .env en la raíz del proyecto (junto a docker-compose.prod.yml)
# y completa con tus valores reales. NO subas el archivo .env real al repositorio.

# Contraseña del usuario postgres
DB_PASSWORD=CambiaEstaPasswordSegura123!

# Secreto usado para firmar los JWT
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# Dominio público de la VM (ej: arriendos360.eastus.cloudapp.azure.com)
# Si todavía no tienes dominio/DNS configurado, usa la IP pública de la VM
# (Caddy servirá por HTTP sin certificado automático en ese caso).
DOMAIN=arriendos360.eastus.cloudapp.azure.com
